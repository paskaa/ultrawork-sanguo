  "taskCategories": {
    "visual-engineering": {
      "description": "UI/前端任务",
      "mainAgent": "zhaoyun",
      "supportingAgents": ["gaoshun", "chendao", "guanping"],
      "keywords": ["UI", "界面", "样式", "前端", "Vue", "页面", "组件", "Element", "CSS", "HTML"],
      "model": "q35model",
      "workflow": ["simayi 探索现有代码", "gaoshun 开发前端", "chendao 开发接口", "guanping 审查代码"]
    },
    "deep": {
      "description": "深度执行 - 复杂功能开发、系统重构",
      "mainAgent": "zhaoyun",
      "supportingAgents": ["gaoshun", "chendao", "simayi", "simashi"],
      "keywords": ["重构", "架构", "实现", "开发", "复杂", "功能", "模块", "系统", "集成", "完善", "优化", "扩展", "迁移", "改造"],
      "model": "kmodel",
      "workflow": ["simayi/simashi 探索代码", "zhouyu/lusu 设计方案", "zhaoyun 统筹实现", "gaoshun/chendao 并行开发"]
    },
    "quick": {
      "description": "快速修复 - Bug 修复、小修改",
      "mainAgent": "zhaoyun",
      "supportingAgents": ["zhangfei", "wulan", "leixu"],
      "keywords": ["bug", "修复", "fix", "小修改", "配置", "调整", "错误", "问题"],
      "model": "q35model",
      "workflow": ["zhangfei/leixu 定位问题", "wulan 快速修复", "zhaoyun 验证"]
    },
    "ultrabrain": {
      "description": "架构设计 - 技术决策、方案设计",
      "mainAgent": "zhouyu",
      "supportingAgents": ["lusu", "huanggai", "zhugeliang"],
      "keywords": ["设计", "方案", "架构", "决策", "规划", "评审", "技术选型", "可行性"],
      "model": "gmodel",
      "workflow": ["lusu 分析需求", "zhouyu 设计方案", "huanggai 原型验证", "zhugeliang 最终决策"]
    },
    "explore": {
      "description": "代码探索 - 搜索、分析、定位",
      "mainAgent": "simayi",
      "supportingAgents": ["simashi", "simazhao"],
      "keywords": ["搜索", "查找", "分析", "探索", "定位", "理解", "代码库", "结构"],
      "model": "mmodel",
      "workflow": ["simayi 快速探索", "simashi 深度分析", "simazhao 整理输出"]
    },
    "security": {
      "description": "安全审计 - 安全漏洞检查、代码审查",
      "mainAgent": "guanyu",
      "supportingAgents": ["zhoucang", "guanping"],
      "keywords": ["安全", "审计", "漏洞", "审查", "check", "review", "风险"],
      "model": "q35model",
      "workflow": ["zhoucang 安全检查", "guanping 代码审查", "guanyu 最终评审"]
    },
    "documentation": {
      "description": "文档编写 - 技术文档、API 文档、使用说明",
      "mainAgent": "simazhao",
      "supportingAgents": ["lusu", "simayi"],
      "keywords": ["文档", "说明", "API", "readme", "注释", "手册"],
      "model": "kmodel",
      "workflow": ["simayi 收集信息", "simazhao 整理编写", "lusu 审核完善"]
    },
    "special": {
      "description": "特殊任务 - 实验性功能、探索性任务",
      "mainAgent": "machao",
      "supportingAgents": ["pangde", "madai"],
      "keywords": ["实验", "探索", "原型", "新技术", "预研"],
      "model": "gmodel",
      "workflow": ["pangde 探索验证", "madai 稳健实现", "machao 统筹"]
    }
  },

  "dispatchRules": {
    "_comment": "任务调度规则 - 根据关键词自动分配将领",
    "frontend": {
      "trigger": ["前端", "UI", "界面", "Vue", "页面", "组件", "Element", "样式", "CSS"],
      "primary": "zhaoyun",
      "secondary": ["gaoshun"],
      "category": "visual-engineering"
    },
    "backend": {
      "trigger": ["后端", "API", "接口", "数据库", "服务", "Spring", "FastAPI"],
      "primary": "zhaoyun",
      "secondary": ["chendao"],
      "category": "visual-engineering"
    },
    "architecture": {
      "trigger": ["架构", "设计", "方案", "决策", "规划", "评审", "技术选型"],
      "primary": "zhouyu",
      "secondary": ["lusu", "huanggai"],
      "category": "ultrabrain"
    },
    "exploration": {
      "trigger": ["探索", "搜索", "查找", "分析", "定位", "理解代码"],
      "primary": "simayi",
      "secondary": ["simashi", "simazhao"],
      "category": "explore"
    },
    "bugfix": {
      "trigger": ["bug", "修复", "错误", "问题", "异常", "fail", "error"],
      "primary": "zhaoyun",
      "secondary": ["zhangfei", "leixu", "wulan"],
      "category": "quick"
    },
    "security": {
      "trigger": ["安全", "审计", "漏洞", "review", "审查"],
      "primary": "guanyu",
      "secondary": ["zhoucang", "guanping"],
      "category": "security"
    },
    "documentation": {
      "trigger": ["文档", "说明", "API 文档", "readme", "手册"],
      "primary": "simazhao",
      "secondary": ["lusu"],
      "category": "documentation"
    },
    "research": {
      "trigger": ["调研", "预研", "实验", "新技术", "原型"],
      "primary": "machao",
      "secondary": ["pangde"],
      "category": "special"
    }
  },

  "statusBar": {
    "_comment": "状态栏显示配置",
    "enabled": true,
