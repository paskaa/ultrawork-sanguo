      { "condition": "contains(['监控', '日志', '异常', 'console', 'network', 'API错误', '告警'], task)", "category": "monitor", "primary_agent": "manchong", "support_agents": ["chengyu", "jiaxu", "liuye"] },
      { "condition": "contains(['单元测试', '集成测试', '覆盖率', 'JUnit', 'Vitest', '写测试'], task)", "category": "test", "primary_agent": "xushu", "support_agents": ["panglin", "yanyan"] },
      { "condition": "contains(['搜索', '查找', '定位', 'find', 'search', 'locate', 'grep'], task)", "category": "explore", "primary_agent": "simayi", "support_agents": ["simashi", "simazhao"] },
      { "condition": "contains(['设计', '方案', '决策', '规划', 'ultrabrain'], task)", "category": "ultrabrain", "primary_agent": "zhouyu", "support_agents": ["lusu", "huanggai"] },
      { "condition": "contains(['修复', 'bug', 'fix', '问题'], task)", "category": "quick", "primary_agent": "zhangfei", "support_agents": ["leixu", "wulan"] },
      { "condition": "contains(['review', '审查', '检查', '质量', 'Code Review'], task)", "category": "review", "primary_agent": "guanyu", "support_agents": ["guanping", "zhoucang"] },
      { "condition": "contains(['UI', 'Vue', '组件', '页面', 'CSS', 'element', '样式', '交互'], task)", "category": "visual-engineering", "primary_agent": "zhaoyun", "support_agents": ["gaoshun"] },
      { "condition": "contains(['重构', '架构', '实现', '开发', '模块', '系统'], task)", "category": "deep", "primary_agent": "zhaoyun", "support_agents": ["chendao"] },
      { "condition": "contains(['文档', 'readme', '说明', '注释', 'document', 'doc'], task)", "category": "writing", "primary_agent": "simayi", "support_agents": ["simazhao"] },
      { "condition": "contains(['特殊', '实验', '备用', '支援', 'reserve'], task)", "category": "reserve", "primary_agent": "machao", "support_agents": ["madai", "pangde"] }
    ],
    "default_category": "deep",
    "default_agent": "zhaoyun"
  },

  "ultrawork": {
    "triggers": ["/ulw", "/ultrawork", "ulw", "ultrawork"],
    "default_orchestrator": "zhugeliang",
    "auto_category_detection": true,
    "parallel_execution": true,
    "max_concurrent_agents": 5,
    "progress_reporting": true
  },

  "dispatch_rules": {
    "description": "主将调用部将的规则配置 - 严格层级：主帅(诸葛亮) → 大都督 → 部将",
    
    "hierarchy_constraints": {
      "strict_mode": true,
      "description": "严格层级调用约束，禁止越级调用",
      "rules": [
        {
          "level": "commander-in-chief",
          "agents": ["zhugeliang"],
          "can_call": ["zhouyu", "zhaoyun", "simayi", "guanyu", "zhangfei", "manchong"],
          "cannot_call": ["lusu", "huanggai", "gaoshun", "chendao", "guanping", "zhoucang", "leixu", "wulan", "madai", "pangde", "chengyu", "jiaxu", "liuye"],
          "error_message": "主帅(诸葛亮)只能调用大都督，禁止直接调用部将。正确调用链：诸葛亮 → 大都督 → 部将"
        },
        {
          "level": "commander",
          "agents": ["zhouyu", "zhaoyun", "simayi", "guanyu", "zhangfei", "manchong", "machao", "xushu"],
          "can_call": "own_subordinates_only",
          "cannot_call": "other_commanders_subordinates",
          "error_message": "大都督只能调用自己的部将，禁止越级调用其他团队的部将"
        },
        {
          "level": "subordinate",
          "agents": ["lusu", "huanggai", "gaoshun", "chendao", "guanping", "zhoucang", "leixu", "wulan", "madai", "pangde", "chengyu", "jiaxu", "liuye", "panglin", "yanyan", "simashi", "simazhao"],
          "can_call": [],
          "report_to": "commander",
          "cannot_call": ["zhugeliang"],
          "error_message": "部将只能向自己的大都督汇报，禁止越级向主帅汇报"
        }
      ],
      "subordinate_mappings": {
        "zhouyu": ["lusu", "huanggai"],
        "zhaoyun": ["gaoshun", "chendao"],
        "guanyu": ["guanping", "zhoucang"],
        "zhangfei": ["leixu", "wulan"],
        "simayi": ["simashi", "simazhao"],
        "machao": ["madai", "pangde"],
        "manchong": ["chengyu", "jiaxu", "liuye"],
        "xushu": ["panglin", "yanyan"]
      }
    },
    
    "complexity_thresholds": {
      "simple": {
        "description": "简单任务，主将独立执行",
        "conditions": ["单文件", "单模块", "<100行代码"],
        "dispatch": false
      },
      "moderate": {
        "description": "中等任务，可能需要部将支援",
        "conditions": ["2-3个文件", "涉及前后端", "需要专业领域"],
        "dispatch": "optional"
      },
      "complex": {
        "description": "复杂任务，必须调用部将",
        "conditions": [">=4个文件", ">1个模块", "可并行子任务"],
        "dispatch": true
      }
    },

    "dispatch_triggers": {
      "parallel_opportunity": {
        "description": "任务可并行分解",
        "action": "同时调用多个部将"
      },
      "domain_specialist": {
        "description": "子任务需要专业领域知识",
        "action": "调用对应专长的部将"
      },
      "exploration_needed": {
        "description": "需要深度探索/分析",
        "action": "调用探索型部将"
      },
      "time_pressure": {
        "description": "紧急任务需要快速交付",
        "action": "并行调用所有可用部将"
      }
    },

    "agent_dispatch_config": {
      "zhaoyun": {
        "support_agents": ["gaoshun", "chendao"],
        "dispatch_modes": {
          "frontend_backend": {
            "trigger": "任务同时涉及前后端",
