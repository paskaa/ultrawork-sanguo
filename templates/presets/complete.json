    "gmodel": {
      "name": "GLM-5",
      "provider": "智谱 AI",
      "cost": "0.5x",
      "features": ["快速响应", "系统工程能力强", "适合调度决策"],
      "useCase": "主帅调度、战略规划、架构设计"
    },
    "q35model": {
      "name": "Qwen3.5-Plus",
      "provider": "阿里云",
