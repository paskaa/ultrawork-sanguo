          },
          "prototype_validation": {
            "trigger": "需要验证技术方案",
            "dispatch": ["huanggai"],
            "parallel": false
          },
          "parallel_analysis": {
            "trigger": "复杂决策需要多维度分析",
            "dispatch": ["lusu", "huanggai"],
            "parallel": true
          }
        }
      },
      "guanyu": {
        "support_agents": ["guanping", "zhoucang"],
        "dispatch_modes": {
          "code_style_review": {
            "trigger": "需要代码规范检查",
            "dispatch": ["guanping"],
            "parallel": true
          },
          "security_audit": {
            "trigger": "涉及安全敏感代码",
            "dispatch": ["zhoucang"],
            "parallel": true
          },
          "full_review": {
            "trigger": "大规模代码审查",
