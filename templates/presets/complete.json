  "commands": {
    "ulw": {
      "description": "UltraWork 调度任务",
      "usage": "/ulw <任务描述>",
      "examples": [
        "/ulw 实现用户登录功能",
        "/ulw 修复登录页面的样式问题"
      ]
    },
    "uls": {
      "description": "查看三国军团状态",
      "usage": "/uls"
    },
    "ulw-loop": {
      "description": "UltraWork 循环模式 - 任务完成前持续执行",
      "usage": "/ulw-loop <任务描述>"
    }
  },

  "modelMapping": {
