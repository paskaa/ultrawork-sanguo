    },

    "execution_flow": {
      "steps": [
        "1. 主将接收任务",
        "2. 评估任务复杂度 (simple/moderate/complex)",
        "3. 判断是否需要调用部将",
        "4. 选择调用模式和目标部将",
        "5. 使用 Task 工具调用部将",
